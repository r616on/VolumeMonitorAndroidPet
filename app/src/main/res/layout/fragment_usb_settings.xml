<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Статус USB -->
    <TextView
        android:id="@+id/usbStatusTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="USB: проверка..."
        android:textSize="16sp"
        android:textColor="#2196F3"
        android:layout_marginBottom="20dp" />

    <!-- Выбранное устройство -->
    <TextView
        android:id="@+id/selectedDeviceTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Устройство не выбрано"
        android:textSize="14sp"
        android:background="#E8F5E8"
        android:padding="10dp"
        android:textColor="#000000"
        android:layout_marginBottom="20dp" />

    <!-- Список USB устройств (Spinner) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="Выберите USB устройство:"
        android:textSize="16sp"
        android:textColor="#000000"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/usbDevicesSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="#F0F0F0"
        android:textColor="#000000"
        android:layout_marginBottom="10dp" />

    <!-- Кнопки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/usbScanButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Сканировать"
            android:layout_marginEnd="10dp" />
    </LinearLayout>

    <!-- Кнопка выбора устройства -->
    <Button
        android:id="@+id/selectDeviceButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выбрать это устройство"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#4CAF50" />

    <!-- Кнопка разрешений -->
    <Button
        android:id="@+id/usbPermissionButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Запросить разрешения для всех"
        android:layout_marginBottom="20dp" />

</LinearLayout>
